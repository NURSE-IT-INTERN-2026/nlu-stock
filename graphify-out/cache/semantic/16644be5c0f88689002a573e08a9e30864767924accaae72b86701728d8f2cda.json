{"nodes": [{"id": "context_nlu_domain", "label": "NLU Stock Management Domain Glossary", "file_type": "document", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_consumable", "label": "Consumable (\u0e2a\u0e34\u0e49\u0e19\u0e40\u0e1b\u0e25\u0e37\u0e2d\u0e07)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Single-use items tracked by lot + quantity. Deducted permanently on dispensing. Examples: cotton, gloves, syringes, medication."}, {"id": "context_durable", "label": "Durable (\u0e04\u0e07\u0e17\u0e19)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reusable equipment. May be tracked by quantity or individually via sub-codes. Examples: trays, stethoscopes, blood pressure monitors."}, {"id": "context_fixed_asset", "label": "Fixed Asset (\u0e04\u0e23\u0e38\u0e1e\u0e31\u0e19\u0e18\u0e38\u0e4c)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "High-value items tracked individually by serial number. Requires annual maintenance. Examples: mannequins, cabinets, beds."}, {"id": "context_track_individually", "label": "track_individually flag", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Boolean on each item. true = UI shows sub-codes, staff selects specific items. false = UI shows quantity breakdown, staff enters amount."}, {"id": "context_dual_unit", "label": "Dual Unit System (Issue Unit + Sub Unit)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Issue unit for dispensing (box, piece, bag). Sub unit for granular tracking (pill, gram). Conversion factor links them. Staff input in either; system converts."}, {"id": "context_dispense", "label": "Dispense (\u0e15\u0e31\u0e14\u0e40\u0e1a\u0e34\u0e01)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Staff removes items from stock for teaching. Consumables: permanent deduction. Durables: marks checked-out with return action."}, {"id": "context_receive", "label": "Receive (\u0e23\u0e31\u0e1a\u0e02\u0e2d\u0e07\u0e40\u0e02\u0e49\u0e32)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Adding new stock. Simple add: select item, enter quantity, lot, expiry."}, {"id": "context_adjustment", "label": "Stock Adjustment", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Admin corrects stock quantity during periodic checks. Requires reason selection and audit trail."}, {"id": "context_maintenance", "label": "Maintenance (Fixed Asset)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Annual inspection of Fixed Assets. Records date, condition, next maintenance date. Configurable cycle per item."}, {"id": "context_item_status", "label": "Item Status Enum", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "available, checked-out, damaged, under-repair, lost, pending-maintenance, disposed."}, {"id": "context_location", "label": "Location Hierarchy (Room > Cabinet > Shelf)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hierarchical storage location. Flat 3 columns in DB (room, cabinet, shelf). No self-reference."}, {"id": "context_role_admin", "label": "Role: Admin", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Full access. Manages master data, users, adjustments, maintenance, reports."}, {"id": "context_role_staff", "label": "Role: Staff", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Dispenses items, receives stock, reports damage, views stock levels."}, {"id": "context_role_instructor", "label": "Role: Instructor", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "View-only access to Dashboard, All Items, and Reports (Phase 1)."}, {"id": "context_tech_stack", "label": "Tech Stack (Next.js 16 + Prisma + PostgreSQL)", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "context_phase1", "label": "Phase 1: Stock Management", "file_type": "rationale", "source_file": "plan-nlu-stock/CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale